# ── Entorno VPS ──────────────────────────────────────────────
# Copia este archivo como .env y completa los valores.
# El archivo .env NUNCA se sube al repositorio.

# Token que identifica este VPS ante api.batidospitaya.com
# Debe coincidir con RESUMEN_TOKEN_VPS en api/resumen_reuniones_ia/auth.php
REUNIONES_API_TOKEN=4f7a2c9e1d8b3650a9f2c8e3b1d7a5c2e8f4b9d3a6c1e7f2b8d5a3c9e6f1b4d7

# URL base de la API en Hostinger (sin slash final)
REUNIONES_API_BASE_URL=https://api.batidospitaya.com/api/resumen_reuniones_ia

# Token del ERP — el VPS lo usa para verificar que DELETE /api/audio/{id}
# viene realmente del endpoint aprobar.php del ERP
# Debe coincidir con RESUMEN_TOKEN_ERP en api/resumen_reuniones_ia/auth.php
RESUMEN_TOKEN_ERP=9a3f6c2e5b8d1470f3a9c8e2b5d7a4c1e8f4b9d3a6c2e7f1b8d5a4c9e3f2b5d8

# Carpeta de almacenamiento de audio en el VPS
AUDIO_DIR=/opt/resumen-reuniones-ia/audio

# Puerto en el que escucha uvicorn (nginx hace el proxy)
PORT=8888
